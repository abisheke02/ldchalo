{
  "name": "ldschools-desktop",
  "version": "1.0.0",
  "description": "LD Schools offline CBT exam player",
  "main": "src/main.js",
  "private": true,
  "scripts": {
    "start":            "electron .",
    "dev":              "electron . --dev",
    "build:renderer":   "node scripts/build-renderer.js",
    "build:win":        "npm run build:renderer && electron-builder --win",
    "build:mac":        "npm run build:renderer && electron-builder --mac",
    "build:linux":      "npm run build:renderer && electron-builder --linux"
  },
  "build": {
    "appId":       "app.ldschools",
    "productName": "LD Schools",
    "directories": { "output": "dist" },
    "files":       ["src/**/*", "renderer/**/*", "assets/**/*", "package.json"],
    "win":         { "target": "nsis",     "icon": "assets/icon.ico"  },
    "mac":         { "target": "dmg",      "icon": "assets/icon.icns", "category": "public.app-category.education" },
    "linux":       { "target": "AppImage", "icon": "assets/icon.png",  "category": "Education" }
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron":         "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}


