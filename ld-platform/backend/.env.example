# ─────────────────────────────────────────────────────────────────────────────
# LD Platform — Backend Environment Variables
# Copy this file to .env and fill in every value before starting the server.
# Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# Comma-separated list of browser origins allowed to call the API.
# In production: your domain. In dev: http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# ── JWT (REQUIRED — server refuses to start without this) ────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX_STRING

# ── Admin Login (stored as bcrypt hash in DB on first start) ─────────────────
# These are the credentials for the Admin portal (/admin).
# Change both before going live. Never use defaults in production.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# In Docker Compose the host is the service name (postgres).
# For external DB (Supabase/RDS) use the full hostname.
DB_HOST=postgres
DB_PORT=5432
DB_NAME=ld_platform
DB_USER=ld_user
DB_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD

# ── Redis ─────────────────────────────────────────────────────────────────────
# Redis is optional — server starts without it (JWT blacklist disabled).
REDIS_URL=redis://redis:6379

# ─────────────────────────────────────────────────────────────────────────────
# SUPABASE — Teacher / Parent OTP login (phone + email)
# ─────────────────────────────────────────────────────────────────────────────
# HOW TO GET THESE:
#   1. Go to https://supabase.com and create a free account
#   2. Click "New Project" — choose a region close to India (Singapore)
#   3. Go to Project Settings → API
#   4. Copy "Project URL"  → paste as SUPABASE_URL below
#   5. Copy "anon public"  → paste as SUPABASE_ANON_KEY below
#   6. Go to Authentication → Providers
#      → Enable "Phone" (uses Twilio under the hood — add Twilio creds there)
#      → Enable "Email" (enabled by default)
# ─────────────────────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ─────────────────────────────────────────────────────────────────────────────
# FIREBASE — Student mobile phone OTP + FCM push notifications
# ─────────────────────────────────────────────────────────────────────────────
# HOW TO GET THESE:
#   1. Go to https://console.firebase.google.com
#   2. Click "Add project" → give it a name → Continue
#   3. Enable Phone Authentication:
#      → Authentication → Sign-in method → Phone → Enable → Save
#   4. Get Service Account key (for backend):
#      → Project Settings (gear icon) → Service Accounts tab
#      → Click "Generate new private key" → Download the JSON file
#   5. Open the downloaded JSON file and copy these fields:
#      → "project_id"    → FIREBASE_PROJECT_ID
#      → "client_email"  → FIREBASE_CLIENT_EMAIL
#      → "private_key"   → FIREBASE_PRIVATE_KEY  (the full -----BEGIN ... END----- string)
#   6. For mobile app (react-native), also download google-services.json:
#      → Project Settings → General → Your apps → Add app (Android)
#      → Download google-services.json → place in mobile/android/app/
# ─────────────────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste the entire private key including -----BEGIN----- and -----END----- lines.
# Replace actual newlines with \n so it fits on one line:
FIREBASE_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----

# ─────────────────────────────────────────────────────────────────────────────
# ANTHROPIC — Claude AI (recommendations + LD classification)
# ─────────────────────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_KEY

# ─────────────────────────────────────────────────────────────────────────────
# RAZORPAY — Payments (INR / UPI / Cards)
# ─────────────────────────────────────────────────────────────────────────────
# Get from: https://razorpay.com → Settings → API Keys → Generate Test Key
# Switch to live keys only when going to production.
RAZORPAY_KEY_ID=rzp_test_REPLACE
RAZORPAY_KEY_SECRET=REPLACE_WITH_SECRET

# ─────────────────────────────────────────────────────────────────────────────
# GOOGLE CLOUD TTS — Text-to-speech for exercise audio
# ─────────────────────────────────────────────────────────────────────────────
# HOW TO GET:
#   1. Go to https://console.cloud.google.com
#   2. Enable "Cloud Text-to-Speech API"
#   3. IAM & Admin → Service Accounts → Create → download JSON key
#   4. Paste the full path to the JSON file below
GOOGLE_APPLICATION_CREDENTIALS=/srv/ld-platform/gcloud-tts-key.json

# ─────────────────────────────────────────────────────────────────────────────
# TWILIO SMS — Weekly parent digest (Sunday evenings)
# ─────────────────────────────────────────────────────────────────────────────
# Get from: https://www.twilio.com/console
# Alternatively use MSG91 (cheaper for India): https://msg91.com
TWILIO_ACCOUNT_SID=REPLACE
TWILIO_AUTH_TOKEN=REPLACE
TWILIO_PHONE=+1XXXXXXXXXX
