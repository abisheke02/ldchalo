# ═══════════════════════════════════════════════════════
#  LD Platform — Environment Variables
#  Copy this file to .env and fill in every value.
#  Place this .env file in the ROOT of the project
#  (same folder as docker-compose.yml).
#  NEVER commit .env to git.
# ═══════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────────
DB_NAME=ld_platform
DB_USER=ld_user
# Generate: openssl rand -base64 32
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# ── Redis ─────────────────────────────────────────────────
# Leave blank = no password (fine on a private server)
REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_LONG_RANDOM_STRING

# ── Supabase (handles teacher/parent OTP login) ───────────
# Get from: supabase.com → your project → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Firebase (handles student mobile login) ───────────────
# Get from: console.firebase.google.com → Project Settings → Service Accounts → Generate key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"

# ── Firebase Web SDK (baked into the frontend at build time) ──
# Get from: console.firebase.google.com → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=AIzaSy_your_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_APP_ID=1:000000000000:web:your_app_id

# ── Admin Portal credentials ──────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_THIS_ADMIN_PASSWORD

# ── URLs ──────────────────────────────────────────────────
# Your server's public address (used in teacher invite links)
WEB_URL=http://YOUR_SERVER_IP_OR_DOMAIN
# Must match what the browser sends in Origin header
ALLOWED_ORIGINS=http://YOUR_SERVER_IP_OR_DOMAIN

# ── Razorpay (school subscriptions) ──────────────────────
# Get from: razorpay.com → Settings → API Keys
# Use rzp_test_ keys until ready for real payments
RAZORPAY_KEY_ID=rzp_test_your_key
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── Anthropic (AI recommendations) ───────────────────────
# Get from: console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your_key

# ── Twilio (weekly parent SMS digest) ────────────────────
# Get from: twilio.com → Console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE=+1xxxxxxxxxx

# ── Google Cloud TTS (voice exercises) ───────────────────
# Path to service account JSON inside the backend container
GOOGLE_APPLICATION_CREDENTIALS=/app/config/google-service-account.json
