# ============================================================
# School Management Platform — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=school_mgmt
DB_USER=school_user
DB_PASSWORD=school_password_change_me

# Redis
REDIS_URL=redis://localhost:6379

# JWT (generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=change_me_to_random_64_char_hex

# App
NODE_ENV=development
PORT=3001
ALLOWED_ORIGINS=http://localhost:5174

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_strong_password

# Claude AI (for timetable, result analysis, AI communication assistant)
ANTHROPIC_API_KEY=sk-ant-...

# Razorpay (for fee online payment — Method 3)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...

# Firebase Admin SDK (for push notifications to parent/teacher app)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# WhatsApp Cloud API (fee reminders, absence alerts, circulars)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Twilio SMS (fallback for OTP/alerts)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=

# Supabase (phone OTP for teachers/parents web login)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Google Cloud (Biometric/GPS integration hooks)
GOOGLE_APPLICATION_CREDENTIALS=./gcloud-service-account.json
