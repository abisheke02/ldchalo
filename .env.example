# ─── Neon PostgreSQL (free tier — neon.tech) ──────────────────────────────────
# Sign up → Create project "school-erp" → Dashboard → Connection Details
NEON_DB_URL=postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# ─── MongoDB Atlas (M0 free — cloud.mongodb.com) ──────────────────────────────
# Sign up → Create M0 cluster → Connect → Drivers → Copy connection string
MONGODB_URL=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=school_erp

# ─── Upstash Redis (free tier — upstash.com) ──────────────────────────────────
# Sign up → Create database (Mumbai / Singapore) → Details → Redis URL (TLS)
UPSTASH_REDIS_URL=rediss://default:password@xxx.upstash.io:6379

# ─── Databricks (enterprise workspace) ───────────────────────────────────────
# Settings → SQL Warehouses → your warehouse → Connection Details
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=dapi_your_personal_access_token
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your_warehouse_id
DATABRICKS_CATALOG=hive_metastore
DATABRICKS_SCHEMA=analytics

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-64-char-string-in-production
JWT_EXPIRES_IN=7d

# ─── API ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ─── AI (Claude — console.anthropic.com) ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Google Cloud (TTS / Speech) ──────────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
GOOGLE_CLOUD_PROJECT_ID=your-project-id

# ─── Supabase (Phone OTP Auth) ────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ─── Firebase (Push Notifications) ───────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Razorpay (Payments) ─────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=your-secret

# ─── WhatsApp Cloud API ───────────────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=your-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-id

# ─── SMTP (Email) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
